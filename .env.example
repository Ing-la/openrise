# ============================================================
# Docker Compose 环境变量模板（根目录）
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- 数据库配置 ---
# PostgreSQL 连接配置（用于 db 容器）
POSTGRES_USER=openrise
POSTGRES_PASSWORD=your_database_password
POSTGRES_DB=openrise

# --- NextAuth 配置 ---
# JWT 签名密钥，用于会话加密
# 生成命令：openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-change-in-production

# 应用对外访问地址（不含路径）
# 开发环境：http://localhost:3000
# 生产环境：https://your-domain.com
NEXTAUTH_URL=http://localhost

# --- Resend 邮件服务（可选）---
# Resend API 密钥：https://resend.com
RESEND_API_KEY=
# 发件人邮箱（验证域名后可自定义）
RESEND_FROM=零壹 <onboarding@resend.dev>

# --- Telegram Bot（可选）---
# Telegram Bot Token：@BotFather 创建
TELEGRAM_BOT_TOKEN=
# Telegram Chat ID：用于接收通知
TELEGRAM_CHAT_ID=
# Telegram 代理（可选）
TELEGRAM_PROXY=

# --- MinIO 对象存储 ---
# MinIO 控制台管理员账户
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO S3 API 配置（可与 ROOT 相同）
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=uploads
MINIO_REGION=
MINIO_USE_SSL=false

# MinIO 端点地址（容器内部通信）
MINIO_ENDPOINT=http://minio:9000

# --- 前端容器环境变量（通过 docker-compose 传递）---
# 以下变量由 docker-compose.yml 自动生成，无需手动设置
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# MINIO_ENDPOINT, MINIO_ACCESS_KEY 等同上