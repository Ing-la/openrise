# ============================================================
# Docker Compose 环境变量（根目录 .env）
# 用于：docker-compose up 时注入到 db、frontend 容器
# 说明：镜像构建不包含这些变量，仅在容器启动时注入
# ============================================================

# --- 数据库（db 容器）---
# 作用：PostgreSQL 连接配置
# 获取：自行设定，与 docker-compose 中 db 服务对应
POSTGRES_USER=openrise
POSTGRES_PASSWORD=openrise_secret
POSTGRES_DB=openrise

# --- NextAuth ---
# NEXTAUTH_SECRET：JWT 签名密钥，用于会话加密
# 获取：本地执行 openssl rand -base64 32 生成随机字符串
NEXTAUTH_SECRET=your-secret-key-change-in-production

# NEXTAUTH_URL：应用对外访问地址（不含路径）
# 获取：自行设定。Docker 通过 nginx 80 端口访问时用 http://localhost；本地 dev 用 http://localhost:3000
NEXTAUTH_URL=http://localhost

# --- Resend 邮件（可选，用于注册验证、找回密码）---
# RESEND_API_KEY：Resend API 密钥
# 获取：https://resend.com 注册 → API Keys 创建
RESEND_API_KEY=

# RESEND_FROM：发件人邮箱
# 获取：验证域名后可自定义；开发可用 onboarding@resend.dev（仅发往你注册的邮箱）
RESEND_FROM=Zero One <onboarding@resend.dev>

# --- MinIO 对象存储 ---
# MINIO_ROOT_USER: MinIO管理控制台用户名
MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD: MinIO管理控制台密码
MINIO_ROOT_PASSWORD=minioadmin
# MINIO_ACCESS_KEY: S3 API访问密钥（可与ROOT相同）
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
# MINIO_SECRET_KEY: S3 API秘密密钥（可与ROOT相同）
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
# MINIO_BUCKET: 存储桶名称
MINIO_BUCKET=uploads
# MINIO_REGION: 区域（可选）
MINIO_REGION=
# MINIO_USE_SSL: 是否使用SSL（内部网络可设为false）
MINIO_USE_SSL=false
