# ============================================================
# Next.js 环境变量模板（frontend/.env）
# 复制此文件为 .env.local 并填入实际值用于本地开发
# ============================================================

# --- 数据库连接 ---
# 本地开发时使用 localhost，生产环境使用容器名称
# 格式：postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL="postgresql://openrise:openrise_secret@127.0.0.1:5432/openrise?sslmode=disable"

# --- NextAuth 配置 ---
# JWT 签名密钥，用于会话加密
# 生成命令：openssl rand -base64 32
NEXTAUTH_SECRET="development-secret-key-change-for-production"
# 应用访问地址（本地开发）
NEXTAUTH_URL="http://localhost:3000"

# --- Resend 邮件服务（可选）---
RESEND_API_KEY=""
RESEND_FROM="零壹 <onboarding@resend.dev>"

# --- Cloudflare Turnstile 人机验证（可选）---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- MinIO 对象存储配置 ---
# 开发环境：http://localhost:9000
# 生产环境：http://minio:9000（容器内部）
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="uploads"
MINIO_REGION=""
MINIO_USE_SSL="false"

# --- Telegram Bot 配置（可选）---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_PROXY=""

# --- 开发环境特定配置 ---
# 运行数据库种子脚本（首次部署时设为 true）
RUN_SEED="false"