# ============================================================
# Next.js 环境变量（frontend/.env）
# 用于：npm run dev 本地开发时，Next.js 会读取此文件
# 说明：Docker 部署时此文件不生效，由 docker-compose 注入
# ============================================================

# --- 数据库 ---
# 作用：Prisma 连接 PostgreSQL
# 获取：本地开发时，docker-compose up db -d 后使用 localhost；格式 postgresql://用户:密码@主机:端口/库名
DATABASE_URL="postgresql://openrise:openrise_secret@localhost:5432/openrise"

# --- NextAuth ---
# NEXTAUTH_SECRET：JWT 签名密钥
# 获取：openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# NEXTAUTH_URL：应用地址。本地 dev 直接访问 3000 端口
# 获取：本地开发用 http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# --- Resend 邮件 ---
# 获取：https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM="OpenRise <onboarding@resend.dev>"

# --- Cloudflare Turnstile 人机验证（可选）---
# 获取：https://dash.cloudflare.com/?to=/:account/turnstile 创建站点
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
