# 数据库连接
# 本地开发：docker-compose up db -d 后使用 localhost
# Docker 部署：docker-compose 会注入，此处可留空或使用占位
DATABASE_URL="postgresql://openrise:openrise_secret@localhost:5432/openrise"

# NextAuth 密钥，生产环境请使用随机字符串：openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Resend 邮件服务（https://resend.com 注册获取 API Key）
RESEND_API_KEY="re_xxxxxxxxxxxx"
# 发件人邮箱，需在 Resend 验证域名后使用；开发可用 onboarding@resend.dev（仅发往你注册的邮箱）
RESEND_FROM="OpenRise <onboarding@resend.dev>"

# Cloudflare Turnstile 人机验证（https://dash.cloudflare.com/?to=/:account/turnstile）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
